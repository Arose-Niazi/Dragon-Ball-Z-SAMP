{
    "files.exclude": {
        "**/.git": true,
        "**/*.amx": true,
        // "**/*.xml": true,
    },
    "search.exclude": {
        "**/.git": true,
        "**/*.amx": true,
        "**/*.dll": true,
        "**/*.html": true,
        "**/*.exe": true,
        "**/*.zip": true,
        ".git/*": true,
        ".vscode/*": true,
        "DLL FILES/*": true,
        "logs/*": true,
        "plugins/*": true
    },
    "emeraldwalk.runonsave": {
        "message": "*** All Start ***",
        "messageAfter": "*** All Complete ***",
        // Show elappsed time for all commands
        "showElapsed": true,
        "commands": [
            {
                "match": "\\.(pwn|inc)$",
                "cmd": "python pre-commit.py ${file}"
            }
        ]
    },
    "[plaintext]": {
        "editor.formatOnSave": false,
        "editor.formatOnPaste": false,
    },
    "files.associations": {
        // "**/qawno/include/*.inc": "plaintext",
    },
    "terminal.integrated.profiles.osx": {
        "bash": {
            "path": "/bin/bash",
            "args": []
        }
    },
    "terminal.integrated.defaultProfile.osx": "bash",
    "editor.formatOnSave": false
}